# Environment Variables for Digital Twin Interview App

# Required for production/online mode
GROQ_API_KEY=your_groq_api_key_here

# Optional - defaults to llama-3.3-70b-versatile
GROQ_MODEL=llama-3.3-70b-versatile

# Optional - for enhanced context retrieval (Upstash Vector)
UPSTASH_VECTOR_REST_URL=your_upstash_vector_url_here
UPSTASH_VECTOR_REST_TOKEN=your_upstash_vector_token_here

# Note: For offline testing, GROQ_API_KEY is not required
# The app will provide mock responses when running without API keys